ba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#353-\u8a2d\u5b9avlan-membership","title":"3.5.3. \u200b\u8a2d\u5b9a\u200bVLAN Membership","text":"<p>Figure 12: config vlan membership-1</p> <p>Figure 13: config vlan membership-2</p> \u200b\u7de8\u865f\u200b \u200b\u6b04\u4f4d\u200b\u540d\u7a31\u200b \u200b\u6b04\u4f4d\u200b\u63cf\u8ff0\u200b 1 Tagged VLAN(s) \u200b\u5c01\u5305\u200b\u7531\u6b64\u200b\u4ecb\u9762\u200b\u51fa\u53bb\u200b\u6642\u200b\u9700\u8981\u200b\u52a0\u200bTag\u200b\u7684\u200bVLAN ID\uff0c\u200b\u53ef\u200b\u8a2d\u5b9a\u200b\u591a\u500b\u200bVLAN 2 Untagged VLAN \u200b\u5c01\u5305\u200b\u7531\u6b64\u200b\u4ecb\u9762\u200b\u51fa\u53bb\u200b\u6642\u200b\u4e0d\u200b\u9700\u8981\u200b\u52a0\u200bTag\u200b\u7684\u200bVLAN ID\uff0c\u200b\u50c5\u80fd\u200b\u8a2d\u5b9a\u200b\u4e00\u500b\u200bVLAN","tags":["Aruba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#354-\u8a2d\u5b9avlan-interface-configuration","title":"3.5.4. \u200b\u8a2d\u5b9a\u200bVLAN Interface Configuration","text":"<p>Figure 14: vlan interface configuration-1</p> <p>Figure 15: vlan interface configuration-2</p> \u200b\u7de8\u865f\u200b \u200b\u6b04\u4f4d\u200b\u540d\u7a31\u200b \u200b\u6b04\u4f4d\u200b\u63cf\u8ff0\u200b 1 Port VLAN ID \u200b\u5c01\u5305\u200b\u5f9e\u6b64\u200b\u4ecb\u9762\u200b\u9032\u4f86\u200b\u6642\u200b\u82e5\u200b\u6c92\u200b\u6709\u200bVLAN Tag\u200b\u5247\u6703\u200b\u52a0\u4e0a\u200b\u6b64\u200bVLAN ID\u200b\u7684\u200bTag\u3002\u200b\u6b64\u200b\u90e8\u5206\u200b\u8a2d\u5b9a\u200b\u8981\u200b\u8207\u200bUntagged VLAN ID\u200b\u8a2d\u5b9a\u200b\u76f8\u540c\u200b\uff0c\u200b\u4e0d\u7136\u200b\u6703\u200b\u9020\u6210\u200b\u9032\u4f86\u200b\u7684\u200b\u5c01\u5305\u200b\u662f\u200b\u88ab\u200b\u8f49\u767c\u200b\u5230\u200bPort VLAN ID\u200b\u800c\u200b\u8981\u200b\u51fa\u53bb\u200b\u7684\u200bUntagged\u200b\u5c01\u5305\u200b\u5247\u6703\u200b\u662f\u200bUntagged VLAN ID 2 Acceptable Frame Type \u200b\u5c01\u5305\u200b\u7531\u6b64\u200b\u4ecb\u9762\u200b\u9032\u4f86\u200b\u6642\u200b\u5141\u8a31\u200b\u7684\u200b\u985e\u578b\u200b - All \u200b\u4e0d\u8ad6\u200b\u662f\u200bTagged\u200b\u6216\u200bUntagged\u200b\u5c01\u5305\u200b\u5747\u200b\u5141\u8a31\u200b - Tagged Only \u200b\u53ea\u200b\u5141\u8a31\u200bTagged\u200b\u5c01\u5305\u200b\uff0c\u200b\u82e5\u200b\u662f\u200bUntagged\u200b\u5c01\u5305\u200b\u5247\u200b\u4e1f\u68c4\u200b - Untagged Only \u200b\u53ea\u200b\u5141\u8a31\u200bUntagged\u200b\u5c01\u5305\u200b\uff0c\u200b\u82e5\u200b\u662f\u200bTagged\u200b\u5c01\u5305\u200b\u5247\u200b\u4e1f\u68c4\u200b 3 Ingress Filtering \u200b\u662f\u5426\u200b\u91dd\u5c0d\u200b\u9032\u5165\u200b\u5c01\u5305\u200b\u7be9\u9078\u200b\u5be6\u65bd\u200b\u7be9\u9078\u200b\uff0c\u200b\u82e5\u200b\u662f\u200b\u555f\u7528\u5247\u200b\u9032\u5165\u200b\u7684\u200b\u5c01\u5305\u200b\u82e5\u200b\u6c92\u200b\u6709\u200b\u5728\u200b\u4ecb\u9762\u200b\u8a2d\u5b9a\u200b\u7684\u200bVLAN ID\u200b\u7bc4\u570d\u200b\u5167\u5247\u200b\u4e1f\u68c4\u200b <p>\u200b\u6b64\u4ea4\u63db\u5668\u200b\u6c92\u200b\u6709\u6240\u200b\u8b02\u200b\u7684\u200bPort Type\u200b\u70ba\u200bAccess\u3001Trunk\u200b\u7b49\u200b\u8a2d\u5b9a\u200b\uff0c\u200b\u6545\u82e5\u8981\u200b\u9054\u200b\u5230\u200b\u4e00\u6a23\u200b\u6548\u679c\u200b\u8a2d\u5b9a\u200b\u65b9\u5f0f\u200b\u5982\u4e0b\u200b</p> <ul> <li>Access\uff1a<ol> <li>\u200b\u65bc\u200bVlan Membership\u200b\u4e2d\u200b\u8a2d\u5b9a\u200bUntagged VLAN\u200b\u70ba\u200b\u60f3\u8981\u200b\u8a2d\u5b9a\u200b\u7684\u200bVLAN ID\uff0cTagged VLAN(s)\u200b\u5247\u70ba\u200b\u7a7a\u767d\u200b</li> <li>\u200b\u65bc\u200bVlan Interface Configuration\u200b\u4e2d\u200b\u8a2d\u5b9a\u200b\u8a72\u200bInterface\u200b\u7684\u200bAcceptable Frame Type\u200b\u70ba\u200bUntagged Only</li> <li>\u200b\u8a2d\u5b9a\u200bPort VLAN ID\u200b\u8207\u200bUntagged VLAN ID\u200b\u76f8\u540c\u200b</li> </ol> </li> <li>Trunk\uff1a<ol> <li>\u200b\u65bc\u200bVlan Membership\u200b\u4e2d\u200b\u8a2d\u5b9a\u200bUntagged VLAN\u200b\u70ba\u200b\u60f3\u8981\u200b\u8a2d\u5b9a\u200b\u7684\u200bVLAN ID\u200b\u6216\u200bNone\uff0cTagged VLAN(s)\u200b\u70ba\u200b\u60f3\u8981\u200b\u7684\u200bVLAN ID\u200b\u5217\u8868\u200b</li> <li>\u200b\u65bc\u200bVlan Interface Configuration\u200b\u4e2d\u200b\u8a2d\u5b9a\u200b\u8a72\u200bInterface\u200b\u7684\u200bAcceptable Frame Type\u200b\u70ba\u200bAll\u200b\u6216\u200bTagged Only</li> <li>\u200b\u82e5\u200b\u8a2d\u5b9a\u200b\u70ba\u200bAll\u200b\u4e14\u200b\u4e5f\u200b\u6709\u200b\u8a2d\u5b9a\u200bUntagged VLAN ID\u200b\u5247\u200bPort VLAN ID\u200b\u9700\u200b\u8207\u200bUntagged VLAN ID\u200b\u76f8\u540c\u200b</li> </ol> </li> </ul>","tags":["Aruba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#36-routing\u8a2d\u5b9a","title":"3.6. Routing\u200b\u8a2d\u5b9a","text":"","tags":["Aruba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#361-\u555f\u7528routing\u529f\u80fd","title":"3.6.1. \u200b\u555f\u7528\u200bRouting\u200b\u529f\u80fd","text":"<p>Figure 16: enable routing</p> <p>\u200b\u555f\u7528\u200bRouting</p> <p>\u200b\u6b64\u200b\u8a2d\u5099\u200b\u5c31\u200b\u53ef\u4ee5\u200b\u64d4\u4efb\u200b\u8def\u7531\u5668\u200b\u529f\u80fd\u200b\uff0c\u200b\u505a\u200b\u70ba\u200b\u5176\u4ed6\u200b\u8a2d\u5099\u200b\u7684\u200b\u9598\u9053\u200b\u6642\u200b\uff0c\u200b\u53ef\u4f9d\u64da\u200b\u8def\u7531\u8868\u200b\u8def\u7531\u200b\u5c01\u5305\u200b\u81f3\u200b\u5916\u90e8\u200b\u9598\u9053\u200b</p> <p>\u200b\u4e0d\u200b\u555f\u7528\u200bRouting</p> <p>\u200b\u6b64\u8a2d\u200b\u5099\u50c5\u200b\u5177\u6709\u200b\u4ea4\u63db\u5668\u200b\u529f\u80fd\u200b\uff0c\u200b\u505a\u200b\u70ba\u200b\u5176\u4ed6\u200b\u8a2d\u5099\u200b\u7684\u200b\u9598\u9053\u200b\u6642\u200b\uff0c\u200b\u4e0d\u6703\u200b\u4f9d\u64da\u200b\u8def\u7531\u8868\u200b\u8def\u7531\u200b\u5c01\u5305\u200b\u81f3\u200b\u5916\u90e8\u200b\u9598\u9053\u200b\uff0c\u200b\u4f46\u200b\u81ea\u5df1\u200b\u672c\u8eab\u200b\u7684\u200b\u5c01\u5305\u200b\u4ecd\u200b\u53ef\u200b\u4f9d\u64da\u200b\u8def\u7531\u8868\u200b\u8def\u7531\u200b\u81f3\u200b\u5916\u90e8\u200b\uff0c\u200b\u6545\u82e5\u200b\u55ae\u7d14\u200b\u53ea\u662f\u200b\u8981\u200b\u53ef\u4ee5\u200b\u5728\u200b\u4e0d\u540c\u200b\u7db2\u6bb5\u200b\u7ba1\u7406\u200b\u6b64\u53f0\u200b\u8a2d\u5099\u200b\u7684\u200b\u8a71\u200b\u4e26\u4e0d\u200b\u9700\u8981\u200b\u555f\u7528\u200bRouting</p>","tags":["Aruba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#362-vlan-ip\u8a2d\u5b9a","title":"3.6.2. VLAN IP\u200b\u8a2d\u5b9a","text":"<p>Figure 17: vlan ip setting-1</p> <p>Figure 18: vlan ip setting-2</p>","tags":["Aruba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#363-\u8a2d\u5b9a\u9810\u8a2d\u9598\u9053","title":"3.6.3. \u200b\u8a2d\u5b9a\u200b\u9810\u8a2d\u200b\u9598\u9053","text":"<p>Figure 19: add default gateway-1</p> <p>Figure 20: add default gateway-2</p>","tags":["Aruba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#37-link-aggregation\u8a2d\u5b9a","title":"3.7. Link Aggregation\u200b\u8a2d\u5b9a","text":"","tags":["Aruba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#371-global-configuration","title":"3.7.1. Global Configuration","text":"<p>Figure 21: link aggregation global configuration</p>","tags":["Aruba","Switch"]},{"location":"blog/aruba/aruba-instant-on-siwtch-local-web-config/#372-\u65b0\u589einterface\u81f3link-aggregation-group\u5167","title":"3.7.2. \u200b\u65b0\u589e\u200bInterface\u200b\u81f3\u200bLink Aggregation Group\u200b\u5167","text":"<p>\u200b\u539f\u6709\u200bInterface\u200b\u4e0a\u200b\u7684\u200bVLAN\u200b\u76f8\u95dc\u200b\u8a2d\u5b9a\u200b\u5c07\u6703\u200b\u7121\u6548\u200b\uff0c\u200b\u6703\u4ee5\u200bTRK\u200b\u4ecb\u9762\u200b\u8a2d\u5b9a\u200b\u70ba\u200b\u4e3b\u200b\uff0c\u200b\u6545\u53ef\u81f3\u200bVLAN Membership\u200b\u8a2d\u5b9a\u200bTRK\u200b\u4ecb\u9762\u20